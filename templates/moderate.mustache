{{!
    @template mod_coursework/moderate

    Example context (json):
    {
        "allocatablename": "Student Name",
        "feedbacks": "array of objects for mod_coursework/feedback",
        "moderator": "Moderator User",
        "lasteditedby": "Editing User",
        "moderationform": "<form>RENDERED MODERATION FORM</form>"
    }
}}

<h2>{{#str}} moderationfor, mod_coursework, {{allocatablename}}{{/str}}</h2>

{{#feedbacks}}
    {{> mod_coursework/feedback}}
{{/feedbacks}}

<h3 class="py-3">{{#str}} moderate, mod_coursework {{/str}}</h3>

<table class="table">
    {{#moderator}}
        <tr>
            <th scope="row">
                {{#str}} moderatedby, mod_coursework {{/str}}
            </th>
            <td>
                {{moderator}}<br>
                <small>{{timemodified}}</small>
            </td>
        </tr>
    {{/moderator}}
    {{#lasteditedby}}
        <tr>
            <th scope="row">
                {{#str}} lasteditedby, mod_coursework {{/str}}
            </th>
            <td>
                {{lasteditedby}}<br>
                <small>{{timemodified}}</small>
            </td>
        </tr>
    {{/lasteditedby}}
</table>

{{{moderationform}}}
