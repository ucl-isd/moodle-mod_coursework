{{!
    @template mod_coursework/feedback/advanced_grading

    Template for displaying advanced grading feedback.

    Example context (json):
    {
        "moderaterimg": "https://moodle.com/moderatorimage.jpg",
        "moderatedby": "Andy Burnham",
        "date": "1782146561",
        "stale": true,
        "modcomment": "Inadequate"
        "agreement": "Disagreed"
    }
}}

<div class="py-3 pl-5 coursework-feedback ">
    <div class="d-flex align-items-center">
        {{#moderaterimg}}
            <div class="mr-2 bg-cover bg-light rounded-circle flex-shrink-0"
                 style="background-image: url('{{moderaterimg}}'); height: 2rem; width: 2rem;"></div>
        {{/moderaterimg}}
        <div>
            {{moderatedby}}
            <div class="small text-muted">
                {{#userdate}}{{date}},{{#str}}strftimedatetime, langconfig{{/str}}{{/userdate}}
            </div>
            {{#stale}}
                <div class="badge badge-pill badge-warning">
                    {{#str}} stalemoderation, mod_coursework {{/str}}
                </div>
            {{/stale}}
        </div>
    </div>

    <div class="chat-bubble-bordered">
        {{! Feedback comment. }}
        {{#modcomment}}
            <div class="small text-muted">
                {{#str}} comment, mod_coursework {{/str}}
            </div>
            <div id="behat-final-feedback-comment">
                {{{.}}}
            </div>
        {{/modcomment}}

        <hr>

        <div>
            <div>{{#str}} moderationagreement, mod_coursework {{/str}}</div>
            <div class="h4" id="behat-final-feedback-grade">
                {{agreement}}
            </div>
        </div>
    </div>
</div>
