{{!
    @template mod_coursework/marking/review

    Example context (json):
    {
        "reviewcriteria": [
            {
                "name": "Criterion 1: Structure and Argument",
                "markers": [
                    {
                        "label": "Marker 1",
                        "score": "8.00",
                        "maxscore": "10.00",
                        "percent": 80,
                        "remark": "<p>The structure was logical and the argument was mostly clear.</p>"
                    },
                    {
                        "label": "Marker 2",
                        "score": "7.00",
                        "maxscore": "10.00",
                        "percent": 70,
                        "remark": "<p>A good effort, but the argument could have been supported with more evidence in places.</p>"
                    }
                ]
            },
            {
                "name": "Criterion 2: Research and Referencing",
                "markers": [
                    {
                        "label": "Marker 1",
                        "score": "15.00",
                        "maxscore": "20.00",
                        "percent": 75,
                        "remark": "<p>Good use of sources, but some minor errors in APA formatting.</p>"
                    }
                ]
            }
        ]
    }
}}
<div class="d-none" id="review-source-wrapper">
    <ul class="pl-3">
    {{#reviewcriteria}}
        <li>
            <div class="line-clamp-2">
                {{name}}
            </div>

            <div class="review-marks animate-enter">
                <div class="row mt-2">
                    {{#markers}}
                    <div class="col-md">
                        {{< mod_coursework/progress }}
                            {{$label}}{{label}}{{/label}}
                        {{/ mod_coursework/progress }}

                        {{#remark}}
                        <div class="mt-2 small d-flex justify-content-between">
                            <span class="text-muted">{{#str}} feedback, mod_coursework {{/str}}</span>
                            <button class="btn muted btn-link p-0" data-action="mod-coursework-copy-feedback" data-copy-to="advancedgrading-criteria-{{criterionid}}-remark" data-copy-source="criterion-{{criterionid}}-marker-{{markerindex}}">
                                <small><i class="fa fa-copy me-1" aria-hidden="true"></i>{{#str}}copytoagreed, coursework{{/str}}</small>
                            </button>
                        </div>
                        <div class="small">
                            <div id="criterion-{{criterionid}}-marker-{{markerindex}}">{{{.}}}</div>
                        </div>
                        {{/remark}}
                    </div>
                    {{/markers}}
                </div>
                <hr>
                <div class="text-right">
                    <button class="btn muted btn-link p-0" data-action="mod-coursework-calculate-average-grade">
                        <small><i class="fa fa-calculator me-1" aria-hidden="true"></i>{{#str}}calculateaveragegrade, coursework{{/str}}</small>
                    </button>
                </div>
            </div>
        </li>
    {{/reviewcriteria}}
    </ul>
</div>

{{#js}}
require(['mod_coursework/agree_marks'], function(agree_marks) {
    agree_marks.init();
});
{{/js}}