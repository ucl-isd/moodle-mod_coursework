<h3>{{{title}}}</h3>
{{#alert}}
    <div class="alert alert-warning">{{{alert}}}</div>
{{/alert}}
<div class="container">
    <div class="row bg-light p-3">
        <div class="col">
            <h3 class="h6">{{#str}}submission, coursework{{/str}}</h3>
            {{{submission}}}
        </div>
        <div class="col-4">
            <h3 class="h6">{{#str}}marker, coursework{{/str}}</h3>
            {{{marker}}}
        </div>

        {{#lasteditedby}}
        <div class="col-4">
            <h3 class="h6">{{#str}}lasteditedby, coursework{{/str}}</h3>
            <ul>
                <li>{{{name}}}</li>
                <li>{{{date}}}</li>
            </ul>
        </div>
        {{/lasteditedby}}
        <div class="col-2">
            {{! TODO this is a temporary form for prototype percentage grade column (CTP-5695) including temporary inline style }}
            <form style="max-width: 150px;">
                <label for="decimal-places" class="d-block"><strong>{{#str}}decimalpoints, quiz{{/str}}</strong></label>
                <input class="form-control" id="decimal-places" name="decimal-places" type="number" step="1" value="0">
            </form>
        </div>
    </div>
</div>
